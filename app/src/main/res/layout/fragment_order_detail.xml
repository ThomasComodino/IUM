<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_gray"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btnBackOrder"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_revert"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="@color/green_super"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvOrderDetailTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dettaglio Ordine"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/green_super"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/btnBackOrder"
        app:layout_constraintBottom_toBottomOf="@id/btnBackOrder"
        app:layout_constraintStart_toEndOf="@id/btnBackOrder"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardOrderInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvOrderDetailTitle">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:id="@+id/tvOrderIdDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ordine: ORD-123456"
                android:textStyle="bold"
                android:textColor="@color/green_super"/>
            <TextView
                android:id="@+id/tvOrderDateDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data: 20/05/2024"
                android:layout_marginTop="4dp"/>
            <TextView
                android:id="@+id/tvOrderStatusDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stato: In elaborazione"
                android:layout_marginTop="4dp"
                android:textColor="@color/orange_accent"
                android:textStyle="bold"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardOrderAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/cardOrderInfo">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Indirizzo di Consegna"
                android:textStyle="bold"
                android:textColor="@color/green_super"/>
            <TextView
                android:id="@+id/tvOrderAddressDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Via Roma 10, Milano"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvOrderItemsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Prodotti Acquistati:"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardOrderAddress"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOrderItems"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvOrderItemsLabel"
        app:layout_constraintBottom_toTopOf="@id/cardOrderTotal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_cart"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardOrderTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TOTALE ORDINE:"
                android:textStyle="bold"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tvOrderTotalDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="€ 0.00"
                android:textColor="@color/green_super"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
