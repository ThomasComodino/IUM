<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvPromoTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Titolo Offerta"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black_text"/>

        <TextView
            android:id="@+id/tvPromoDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categoria: Bevande | Sconto: 10%"
            android:textColor="@color/green_super"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvPromoValidity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Valida fino al: 31/12/2024"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvPromoStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATO: ATTIVO"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTogglePromo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DISATTIVA"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeletePromo"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RIMUOVI"
                android:textColor="@color/red_error"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
