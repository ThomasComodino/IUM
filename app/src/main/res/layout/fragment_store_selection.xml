<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_gray"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvStoreTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scegli il Supermercato"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/green_super"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvStoreSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seleziona il punto vendita più vicino a te"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvStoreTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <RadioGroup
        android:id="@+id/rgStores"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvStoreSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rbStoreCentro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SUperSpan, Via Dante 1, Milano"
            android:textSize="18sp"
            android:padding="16dp"
            android:checked="true"/>

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rbStoreNord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SUperSpan, Viale Monza 10, Milano"
            android:textSize="18sp"
            android:padding="16dp"/>

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rbStoreSud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SUperSpan, Via dei Missaglia 45, Milano"
            android:textSize="18sp"
            android:padding="16dp"/>

    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="AVANTI"
        android:textAllCaps="true"
        android:textSize="16sp"
        android:backgroundTint="@color/green_super"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>