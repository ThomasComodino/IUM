<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <TextView
        android:id="@+id/tvDetailCandidateName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nome Candidato"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/black_text"/>

    <TextView
        android:id="@+id/tvDetailRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ruolo"
        android:textColor="@color/green_super"
        android:textSize="18sp"
        android:layout_marginTop="4dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginVertical="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sintesi Profilo:"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tvExperience"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Esperienza: 3 anni nel settore retail. Disponibile a turni weekend."
        android:layout_marginTop="8dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApprove"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="APPROVA E CONTATTA"
        android:layout_marginTop="40dp"
        android:backgroundTint="@color/green_super"/>

</LinearLayout>