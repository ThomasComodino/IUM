<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <ImageButton
        android:id="@+id/btnBackDetail"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_revert"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="@color/green_super"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvDetailCandidateName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nome Candidato"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/black_text"/>

    <TextView
        android:id="@+id/tvDetailRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ruolo"
        android:textColor="@color/green_super"
        android:textSize="18sp"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvDetailLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sede: Milano Bovisa"
        android:textSize="14sp"
        android:layout_marginTop="2dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginVertical="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Documentazione:"
        android:textStyle="bold"
        android:textSize="16sp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewCV"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="APRI CV (PDF)"
        android:layout_marginTop="8dp"
        app:icon="@android:drawable/ic_menu_save"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewVideo"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GUARDA VIDEO PRESENTAZIONE"
        android:layout_marginTop="8dp"
        app:icon="@android:drawable/ic_menu_slideshow"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginVertical="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Azioni Responsabile:"
        android:textStyle="bold"
        android:textSize="16sp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnForwardHR"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="INOLTRA A HR SPECIALIST"
        android:layout_marginTop="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnForwardStore"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="INOLTRA A RESP. NEGOZIO"
        android:layout_marginTop="8dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApprove"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="CONTATTA"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/green_super"/>

</LinearLayout>
